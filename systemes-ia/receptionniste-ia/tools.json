    "function": {
      "name": "availableSlots",
      "description": "Obtenir les créneaux disponibles pour un rendez-vous de taillage de haies. Appeler quand le client veut prendre rendez-vous.",
      "parameters": {
        "type": "object",
        "properties": {
          "preferredDate": {
            "description": "Date préférée au format YYYY-MM-DD",
            "type": "string"
          },
          "preferredTime": {
            "description": "Heure préférée au format HH:MM (ex: 10:00, 13:00)",
            "type": "string"
          }
        }
      }
    },
