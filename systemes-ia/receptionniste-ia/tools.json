    "function": {
      "name": "transferCall",
      "description": "Transférer l'appel à un humain. Utiliser quand: client fâché, demande complexe, urgence, demande commerciale, ou le client veut parler à quelqu'un.",
      "parameters": {
        "type": "object",
        "properties": {
          "reason": {
            "description": "Raison du transfert",
            "type": "string",
            "enum": [
              "angry_client",
              "complex_quote",
              "emergency",
              "commercial",
              "escalation"
            ]
          },
          "destination": {
            "description": "Numéro de destination (optionnel, défaut: Henri)",
            "type": "string"
          }
        },
        "required": [
          "reason"
        ]
      }
    },
    "messages": [
      {
        "type": "request-start",
        "content": "Je vous transfère tout de suite."
