    "updatedAt": "2026-03-31T21:54:09.470Z",
    "type": "function",
    "function": {
      "name": "bookAppointment",
      "description": "Réserver un rendez-vous de taillage de haies. Appeler SEULEMENT quand on a: nom complet, téléphone, adresse, ville, type de haie, nombre de côtés, et créneau choisi.",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "description": "Ville",
            "type": "string"
          },
          "notes": {
            "description": "Notes additionnelles (dessus, gouttières, vitres, etc.)",
            "type": "string"
          },
          "phone": {
            "description": "Numéro de téléphone à 10 chiffres",
            "type": "string"
          },
          "address": {
            "description": "Adresse de la propriété",
            "type": "string"
          },
          "hedgeType": {
            "description": "Type de haie: cèdre, feuillue, mixte, autre",
            "type": "string"
          },
          "clientName": {
            "description": "Nom complet du client",
            "type": "string"
          },
          "hedgeSides": {
            "description": "Nombre de côtés à tailler (1-4)",
            "type": "number"
          },
          "hedgeHeight": {
            "description": "Hauteur: basse, moyenne, haute, très-haute",
            "type": "string"
          },
          "selectedSlot": {
            "description": "Créneau sélectionné",
            "type": "object",
            "required": [
              "date",
              "time"
            ],
            "properties": {
              "date": {
                "description": "Date YYYY-MM-DD",
                "type": "string"
              },
              "time": {
                "description": "Heure HH:MM",
                "type": "string"
              }
            }
          }
        },
        "required": [
          "clientName",
          "phone",
          "address",
          "city",
          "hedgeType",
          "hedgeSides",
          "selectedSlot"
        ]
      }
    },
    "messages": [
      {
        "type": "request-start",
        "content": "Je réserve votre rendez-vous."
      },
      {
        "type": "request-failed",
        "content": "Excusez-moi, petit problème technique. On vous rappelle demain."
      }
    ],
